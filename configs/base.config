# === Aruba AP-305 — image "base" (publique) ===
# Equivalent d une release officielle OpenWrt : defauts du device + LuCI.
# A publier : le squashfs-sysupgrade.bin (l initramfs produit n est pas publie,
# c est la variante ramboot qui couvre ce besoin).
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_aruba_ap-305=y
CONFIG_PACKAGE_luci=y
