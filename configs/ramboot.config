# === Aruba AP-305 — minimal ramboot image (.ari < 8 MB) ===
CONFIG_TARGET_ipq40xx=y
CONFIG_TARGET_ipq40xx_generic=y
CONFIG_TARGET_ipq40xx_generic_DEVICE_aruba_ap-305=y

# initramfs only, XZ-compressed (no squashfs/sysupgrade from this build —
# the RAM-boot image is disposable and must never be flashed to NAND)
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_XZ=y
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set

# No IPv6 userspace (kernel IPv6 cannot be disabled in 24.10)
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set

# Trim everything not needed to boot, serve DHCP and run a sysupgrade
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
# CONFIG_PACKAGE_opkg is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-dwc3 is not set
# CONFIG_PACKAGE_kmod-usb-dwc3-qcom is not set

# Minimal LuCI GUI (plain HTTP, bootstrap theme)
CONFIG_PACKAGE_luci-light=y
